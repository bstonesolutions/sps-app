{
  "crons": [
    { "path": "/api/cron-automations", "schedule": "0 * * * *" },
    { "path": "/api/owner-digest", "schedule": "0 * * * *" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
