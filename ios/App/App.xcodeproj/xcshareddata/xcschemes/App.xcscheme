            <ActionContent
               title = "Name archive: &lt;build&gt; SPS Way"
               scriptText = "# Rename the Organizer archive to &quot;&lt;buildNumber&gt; SPS Way&quot;, e.g. &quot;12 SPS Way&quot;.&#10;ARCHIVE_INFO=&quot;${ARCHIVE_PATH}/Info.plist&quot;&#10;if [ -f &quot;${ARCHIVE_INFO}&quot; ]; then&#10;  BUILD=$(/usr/libexec/PlistBuddy -c &quot;Print :ApplicationProperties:CFBundleVersion&quot; &quot;${ARCHIVE_INFO}&quot; 2&gt;/dev/null)&#10;  if [ -z &quot;${BUILD}&quot; ]; then BUILD=&quot;${CURRENT_PROJECT_VERSION}&quot;; fi&#10;  /usr/libexec/PlistBuddy -c &quot;Set :Name ${BUILD} SPS Way&quot; &quot;${ARCHIVE_INFO}&quot; 2&gt;/dev/null || /usr/libexec/PlistBuddy -c &quot;Add :Name string ${BUILD} SPS Way&quot; &quot;${ARCHIVE_INFO}&quot;&#10;fi&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "504EC3031FED79650016851F"
                     BuildableName = "SPS Way.app"
                     BlueprintName = "App"
                     ReferencedContainer = "container:App.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
