<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>SPS Way</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.stonepropertysolutions.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>spsway</string>
			</array>
		</dict>
	</array>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Privacy usage strings — REQUIRED or iOS hard-crashes (TCC) the moment the
	     camera / photo library / mic is touched. Adding a stop photo or video opens
	     the camera + photo picker; video also captures audio. -->
	<key>NSCameraUsageDescription</key>
	<string>Stone Property Solutions uses the camera to add photos and videos to a service stop and a client's file.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Stone Property Solutions lets you attach photos and videos from your library to a service stop and a client's file.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Stone Property Solutions can save service photos to your photo library.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Stone Property Solutions uses the microphone to record audio when you capture a video on a service stop.</string>
	<!-- Location: live staff position while the app is active plus one power-efficient background
	     region for the next assigned stop. Region entry only prompts the tech to confirm arrival. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>SPS Way uses your location in the background only while an assigned stop is active so it can remind you to open the app and confirm when you arrive. Arrival detection never contacts the client automatically.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SPS Way uses your location for route timing, active-stop tracking, and arrival confirmation while you work.</string>
	<!-- The app monitors one assigned-stop region so iOS can wake it to show an arrival-check
	     notification. It does not run continuous background GPS tracking. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
	<!-- Export compliance: app uses only standard HTTPS/TLS, so it qualifies for the exemption.
	     Set so TestFlight/App Store uploads don't prompt "Missing Compliance" every time. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
